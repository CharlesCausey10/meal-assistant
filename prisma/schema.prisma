generator client {
    provider   = "prisma-client-js"
    engineType = "library"
}

datasource db {
    provider = "postgresql"
}

enum Protein {
    CHICKEN_BREAST
    CHICKEN_THIGHS
    ROTISSERIE_CHICKEN
    GROUND_BEEF
    PORK_BUTT
    FISH
    EGGS
}

enum Category {
    BREAKFAST
    LUNCH
    DINNER
    SIDE_STARTER
    SNACK
    DESSERT
}

enum IngredientCategory {
    PRODUCE
    MEAT
    SEAFOOD
    DAIRY
    DRINKS
    GRAINS_BREAD
    NUTS_SEEDS
    BAKING
    OILS_VINEGARS
    CONDIMENTS
    CANNED_GOODS
    FROZEN
    SNACKS_CHIPS
    SPICES_HERBS
    SWEETS
    OTHER
}

model Meal {
    id          Int              @id @default(autoincrement())
    name        String
    protein     Protein?
    category    Category
    preference  Int?
    notes       String?
    recipeUrl   String?
    ingredients MealIngredient[]
    groceryUses GroceryListMeal[]
    createdAt   DateTime         @default(now())
}

model Ingredient {
    id        Int                @id @default(autoincrement())
    name      String             @unique
    category  IngredientCategory
    mealUses  MealIngredient[]
    groceryListItems GroceryListItem[]
    createdAt DateTime           @default(now())
}

model MealIngredient {
    id           Int        @id @default(autoincrement())
    mealId       Int
    meal         Meal       @relation(fields: [mealId], references: [id], onDelete: Cascade)
    ingredientId Int
    ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
    quantity     Decimal
    unit         String
    createdAt    DateTime   @default(now())

    @@unique([mealId, ingredientId])
}

model MealLog {
    id        Int      @id @default(autoincrement())
    name      String
    protein   Protein?
    cookedAt  DateTime
    createdAt DateTime @default(now())
}

model GroceryList {
    id          Int               @id @default(autoincrement())
    name        String
    notes       String?
    items       GroceryListItem[]
    sourceMeals GroceryListMeal[]
    createdAt   DateTime          @default(now())
    updatedAt   DateTime          @updatedAt
}

model GroceryListMeal {
    id            Int         @id @default(autoincrement())
    groceryListId Int
    mealId        Int
    groceryList   GroceryList @relation(fields: [groceryListId], references: [id], onDelete: Cascade)
    meal          Meal        @relation(fields: [mealId], references: [id], onDelete: Cascade)
    createdAt     DateTime    @default(now())

    @@unique([groceryListId, mealId])
}

model GroceryListItem {
    id            Int                 @id @default(autoincrement())
    groceryListId Int
    ingredientId  Int?
    nameSnapshot  String
    category      IngredientCategory?
    quantity      Decimal?
    unit          String?
    note          String?
    isChecked     Boolean             @default(false)
    sortOrder     Int                 @default(0)
    groceryList   GroceryList         @relation(fields: [groceryListId], references: [id], onDelete: Cascade)
    ingredient    Ingredient?         @relation(fields: [ingredientId], references: [id], onDelete: SetNull)
    createdAt     DateTime            @default(now())
    updatedAt     DateTime            @updatedAt

    @@index([groceryListId, isChecked])
    @@index([groceryListId, category])
}
