generator client {
    provider   = "prisma-client-js"
    engineType = "library"
}

datasource db {
    provider = "postgresql"
}

enum Protein {
    CHICKEN_BREAST
    CHICKEN_THIGHS
    ROTISSERIE_CHICKEN
    GROUND_BEEF
    PORK_BUTT
    FISH
    EGGS
}

enum Category {
    BREAKFAST
    LUNCH
    DINNER
    SIDE_STARTER
    SNACK
    DESSERT
}

enum IngredientCategory {
    PRODUCE
    MEAT
    SEAFOOD
    DAIRY
    GRAINS_BREAD
    NUTS_SEEDS
    BAKING
    OILS_VINEGARS
    CONDIMENTS
    CANNED_GOODS
    FROZEN
    SPICES_HERBS
    SWEETS
    OTHER
}

model Meal {
    id          Int              @id @default(autoincrement())
    name        String
    protein     Protein?
    category    Category
    preference  Int?
    notes       String?
    recipeUrl   String?
    ingredients MealIngredient[]
    createdAt   DateTime         @default(now())
}

model Ingredient {
    id        Int                @id @default(autoincrement())
    name      String             @unique
    category  IngredientCategory
    mealUses  MealIngredient[]
    createdAt DateTime           @default(now())
}

model MealIngredient {
    id           Int        @id @default(autoincrement())
    mealId       Int
    meal         Meal       @relation(fields: [mealId], references: [id], onDelete: Cascade)
    ingredientId Int
    ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
    quantity     Decimal
    unit         String
    createdAt    DateTime   @default(now())

    @@unique([mealId, ingredientId])
}

model MealLog {
    id        Int      @id @default(autoincrement())
    name      String
    protein   Protein?
    cookedAt  DateTime
    createdAt DateTime @default(now())
}
